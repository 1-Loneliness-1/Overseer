<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivServerStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_gravity="center"
        android:scaleType="centerCrop"
        android:src="@drawable/server_is_ok"
        app:layout_constraintBottom_toTopOf="@id/tvServerAvailability"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/padding_16"
        app:layout_constraintHeight_percent="0.50"
        app:layout_constraintWidth_percent="0.50"
        app:shapeAppearanceOverlay="@style/RoundedImage" />

    <TextView
        android:id="@+id/tvServerAvailability"
        style="@style/StatsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/server_is_ok"
        android:textSize="@dimen/text_size_30"
        android:layout_marginTop="@dimen/padding_8"
        app:layout_constraintBottom_toTopOf="@id/tvServerStats"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivServerStatus" />

    <TextView
        android:id="@+id/tvServerStats"
        style="@style/StatsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_8"
        android:gravity="center"
        android:text="@string/server_stats"
        android:textSize="@dimen/text_size_24"
        app:layout_constraintBottom_toTopOf="@id/ivLine"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/padding_16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvServerAvailability" />

    <ImageView
        android:id="@+id/ivLine"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@drawable/black_line"
        android:layout_marginHorizontal="64dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="@dimen/padding_8"
        app:layout_constraintBottom_toTopOf="@id/llServerMetrics"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvServerStats" />

    <LinearLayout
        android:id="@+id/llServerMetrics"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:layout_marginHorizontal="@dimen/padding_16"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivLine">

        <include
            android:id="@+id/iCpuMetric"
            layout="@layout/metric_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_8" />

        <include
            android:id="@+id/iRamMetric"
            layout="@layout/metric_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_8" />

        <include
            android:id="@+id/iDiskMetric"
            layout="@layout/metric_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_8" />

        <include
            android:id="@+id/iUptimeMetric"
            layout="@layout/metric_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_8" />

        <include
            android:id="@+id/iVpnMetric"
            layout="@layout/metric_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_8" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>